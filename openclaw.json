{
  "gateway": {
    "port": 7860,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "https://*.hf.space",
        "http://localhost:7860",
        "http://127.0.0.1:7860"
      ],
      "dangerouslyAllowHostHeaderOriginFallback": true
    },
    "auth": {
      "mode": "token",
      "token": "__GATEWAY_TOKEN__"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },

  "models": {
    "providers": {
      "nim": {
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "apiKey": "__NVIDIA_API_KEY__",
        "api": "openai-completions",
        "models": [
          {
            "id": "moonshotai/kimi-k2.6",
            "name": "Kimi K2.6",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "deepseek-ai/deepseek-v4-pro",
            "name": "DeepSeek V4 Pro",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "thudm/glm-5.1",
            "name": "GLM 5.1",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384
          },
          {
            "id": "qwen/qwen3-coder-480b-a35b",
            "name": "Qwen3 Coder 480B",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 262144,
            "maxTokens": 32768
          },
          {
            "id": "nvidia/nemotron-3-super-120b",
            "name": "Nemotron 3 Super 120B",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 131072,
            "maxTokens": 16384
          }
        ]
      },
      "nim-image": {
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "apiKey": "__NVIDIA_API_KEY__",
        "api": "openai-completions",
        "models": [
          {
            "id": "stabilityai/stable-diffusion-3.5-large",
            "name": "Stable Diffusion 3.5 Large",
            "input": ["text"],
            "contextWindow": 4096,
            "maxTokens": 0
          },
          {
            "id": "black-forest-labs/flux-2-klein-4b",
            "name": "FLUX 2 Klein 4B",
            "input": ["text"],
            "contextWindow": 4096,
            "maxTokens": 0
          },
          {
            "id": "qwen/qwen-image",
            "name": "Qwen Image",
            "input": ["text"],
            "contextWindow": 4096,
            "maxTokens": 0
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "nim/moonshotai/kimi-k2.6"
      },
      "imageModel": {
        "primary": "nim-image/stabilityai/stable-diffusion-3.5-large"
      },
      "models": {
        "nim/moonshotai/kimi-k2.6": {},
        "nim/deepseek-ai/deepseek-v4-pro": {},
        "nim/thudm/glm-5.1": {},
        "nim/qwen/qwen3-coder-480b-a35b": {},
        "nim/nvidia/nemotron-3-super-120b": {},
        "nim-image/stabilityai/stable-diffusion-3.5-large": {},
        "nim-image/black-forest-labs/flux-2-klein-4b": {},
        "nim-image/qwen/qwen-image": {}
      },
      "workspace": "/home/openclaw/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      }
    }
  },

  "tools": {
    "profile": "full",
    "web": {
      "search": {
        "enabled": true,
        "provider": "gemini",
        "gemini": {
          "apiKey": "__GEMINI_API_KEY__",
          "model": "gemini-3.1-flash-lite"
        },
        "maxResults": 5,
        "timeoutSeconds": 30
      }
    },
    "exec": {
      "security": "allowlist",
      "ask": "on-miss"
    },
    "fs": {
      "workspaceOnly": true
    }
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },

  "session": {
    "dmScope": "per-channel-peer"
  },

  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw"
  }
}
